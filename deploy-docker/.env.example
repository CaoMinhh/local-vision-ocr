# Local Vision OCR - Docker Environment Configuration

# FastAPI app metadata
APP_TITLE=OCR → MD/JSON
APP_VERSION=0.1.0

# Server configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# CORS configuration (comma-separated origins, or * for all)
CORS_ALLOW_ORIGINS=*

# Ollama configuration
# When using docker-compose, use: http://ollama:11434
# When using docker-compose on host network, use: http://127.0.0.1:11434
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=nemotron3:33b
OLLAMA_THINK=1
OLLAMA_TIMEOUT_SEC=600
# OLLAMA_KEEP_ALIVE=5m

# OCR / vision payload configuration
OCR_PDF_SCALE=2.0
OCR_MAX_PARALLEL=1
OCR_BACKGROUND_MAX_CONCURRENT=2
OCR_MAX_EDGE=0
OCR_JPEG_QUALITY=

# GPU panel (optional)
NVIDIA_SMI_PATH=nvidia-smi
NVIDIA_SMI_TIMEOUT_SEC=8
GPU_WS_INTERVAL_SEC=1.5

# MongoDB configuration (OCR history)
# Format for docker-compose: mongodb://admin:password@mongo:27017 (if using mongo service with credentials)
# Format for external MongoDB: mongodb+srv://USER:PASS@cluster.../DBNAME?retryWrites=true&w=majority
MONGODB_URI=mongodb://admin:password@mongo:27017
MONGODB_DB_NAME=nemotron3_ocr
MONGODB_COLLECTION_OCR=ocr_runs
MONGODB_COLLECTION_APP_SETTINGS=ocr_app_settings

# MongoDB history storage
OCR_HISTORY_STORE_INPUT_B64=1
OCR_HISTORY_MAX_INPUT_BYTES=6000000
