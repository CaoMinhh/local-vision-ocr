# Copy to .env and adjust. Loaded automatically from project root when importing backend_ocr.main.

# --- FastAPI app metadata ---
APP_TITLE=OCR → MD/JSON
APP_VERSION=0.1.0

# --- Uvicorn (`python -m backend_ocr.main` or `python app.py`) ---
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# CORS: comma-separated origins, or * for all
CORS_ALLOW_ORIGINS=*

# --- Ollama ---
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=nemotron3:33b
# Ollama /api/chat: think true|false (models that support it). Form OCR can override per request.
OLLAMA_THINK=1
OLLAMA_TIMEOUT_SEC=600
# Ollama /api/chat keep_alive: empty = default (model stays loaded). 0 = unload from VRAM after each request (slower next run). Or e.g. 5m, 30s.
# OLLAMA_KEEP_ALIVE=0

# --- OCR / vision payload ---
# PyMuPDF rasterization scale (higher = sharper, slower)
OCR_PDF_SCALE=2.0
# Max concurrent Ollama requests for multi-page PDFs (raise only if VRAM allows)
OCR_MAX_PARALLEL=1
# Max concurrent background OCR jobs (POST /api/ocr/job); queued jobs wait on disk
OCR_BACKGROUND_MAX_CONCURRENT=2
# Max longest image edge in pixels; 0 = no downscale
OCR_MAX_EDGE=0
# JPEG quality 1–100 for vision images; leave empty to send PNG
OCR_JPEG_QUALITY=

# --- GPU panel (optional) ---
NVIDIA_SMI_PATH=nvidia-smi
NVIDIA_SMI_TIMEOUT_SEC=8
GPU_WS_INTERVAL_SEC=1.5

# --- MongoDB (OCR history) ---
# Atlas example: mongodb+srv://USER:PASS@cluster.../DBNAME?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://USER:PASS@cluster.../DBNAME?retryWrites=true&w=majority
MONGODB_DB_NAME=nemotron3_ocr
MONGODB_COLLECTION_OCR=ocr_runs
# App settings document in MongoDB (Ollama, OCR, …) when MONGODB_URI is set
MONGODB_COLLECTION_APP_SETTINGS=ocr_app_settings
# Store each original upload (image or PDF) as base64 on the history record for re-download.
OCR_HISTORY_STORE_INPUT_B64=1
# Max raw bytes per file to store (0 = never store). Keep total document under MongoDB 16MB.
OCR_HISTORY_MAX_INPUT_BYTES=6000000
